# GED-PME — variables d'environnement (copier vers .env)

# URL publique de l'application (liens dans les alertes WhatsApp)
APP_BASE_URL=http://localhost:5000

# WhatsApp — alertes automatiques
WHATSAPP_ENABLED=true
WHATSAPP_PROVIDER=callmebot
DEFAULT_PHONE_PREFIX=+243

# CallMeBot (gratuit) : clé globale optionnelle si tous les users n'ont pas leur propre clé
# CALLMEBOT_API_KEY=

# Proxy réseau (uniquement si votre connexion passe par un proxy)
# HTTPS_PROXY=http://proxy.example.com:8080

# Twilio WhatsApp (entreprise)
# WHATSAPP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta WhatsApp Cloud API (entreprise)
# WHATSAPP_PROVIDER=meta
# WHATSAPP_META_TOKEN=
# WHATSAPP_META_PHONE_ID=

# Email SMTP (envoi de documents)
# MAIL_ENABLED=true
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM=
